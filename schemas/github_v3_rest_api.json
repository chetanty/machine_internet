          "type": "string",
          "required": true,
          "description": "The title of the issue.",
          "enum": null
        },
        {
          "name": "body",
          "type": "string",
          "required": false,
          "description": "The contents of the issue.",
          "enum": null
        },
        {
          "name": "milestone",
          "type": "integer",
          "required": false,
          "description": "The number of the milestone to associate with this issue.",
          "enum": null
        },
        {
          "name": "labels",
          "type": "array[string]",
          "required": false,
          "description": "Labels to associate with this issue. Only users with push access can set labels for new issues.",
          "enum": null
        },
        {
          "name": "assignees",
          "type": "array[string]",
          "required": false,
          "description": "Logins for Users to assign to this issue. Only users with push access can set assignees for new issues.",
          "enum": null
        },
        {
          "name": "issue_field_values",
          "type": "array[object]",
          "required": false,
          "description": "An array of issue field values to set on this issue. Each field value must include the field ID and the value to set. E.g., `[{'field_id': 123, 'value': 'Urgent'}]`.",
          "enum": null
        },
        {
          "name": "type",
          "type": "string",
          "required": false,
          "description": "The name of the issue type to associate with this issue. Only users with push access can set the type for new issues.",
          "enum": null
        }
