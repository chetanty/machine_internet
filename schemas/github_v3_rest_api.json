    {
      "name": "update_issue",
      "description": "Updates an existing issue in a repository. Agents can modify the issue's title, body, change its state (open/closed) and provide a reason, update its milestone, replace all labels, replace all assignees, update custom field values, or change its type.",
      "parameters": [
        {
          "name": "owner",
          "type": "string",
          "required": true,
          "description": "The account owner of the repository.",
          "enum": null
        },
        {
          "name": "repo",
          "type": "string",
          "required": true,
          "description": "The name of the repository.",
          "enum": null
        },
        {
          "name": "issue_number",
          "type": "integer",
          "required": true,
          "description": "The number that identifies the issue.",
          "enum": null
        },
        {
          "name": "title",
          "type": "string",
          "required": false,
          "description": "The new title of the issue.",
          "enum": null
        },
        {
          "name": "body",
          "type": "string",
          "required": false,
          "description": "The new contents of the issue.",
          "enum": null
        },
        {
          "name": "state",
          "type": "string",
          "required": false,
          "description": "The open or closed state of the issue. Can be 'open' or 'closed'.",
          "enum": null
        },
        {
          "name": "state_reason",
          "type": "string",
          "required": false,
          "description": "The reason for the state change. Ignored unless 'state' is changed. Can be 'completed', 'not_planned', 'reopened'.",
          "enum": null
        },
        {
          "name": "milestone",
          "type": "integer",
          "required": false,
          "description": "The number of the milestone to associate with this issue. Pass 'null' to remove a milestone.",
          "enum": null
        },
        {
          "name": "labels",
          "type": "array[string]",
          "required": false,
          "description": "Labels to associate with this issue. Pass one or more labels to _replace_ the set of labels. Send an empty array (`[]`) to clear all labels. Only users with push access can set labels.",
          "enum": null
        },
        {
          "name": "assignees",
          "type": "array[string]",
          "required": false,
          "description": "Usernames to assign to this issue. Pass one or more user logins to _replace_ the set of assignees. Send an empty array (`[]`) to clear all assignees. Only users with push access can set assignees.",
          "enum": null
        },
        {
          "name": "issue_field_values",
          "type": "array[object]",
          "required": false,
          "description": "An array of issue field values to set on this issue. Each field value must include the field ID and the value to set. Only users with push access can set field values.",
          "enum": null
        },
        {
          "name": "type",
          "type": "string",
          "required": false,
          "description": "The name of the issue type to associate with this issue or use `null` to remove the current issue type. Only users with push access can set the type.",
          "enum": null
        }
      ],
