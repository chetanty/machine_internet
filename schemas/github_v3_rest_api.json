    {
      "name": "create_issue",
      "description": "Creates a new issue in a specified repository. Agents must provide a title, and can optionally include a body, assignees, labels, a milestone, custom issue field values, or an issue type.",
      "parameters": [
        {
          "name": "owner",
          "type": "string",
          "required": true,
          "description": "The account owner of the repository.",
          "enum": null
