{
  "base_url": "https://api.github.com",
  "service_name": "github_issues_api",
  "service_description": "Manages issues and their associated resources like comments, labels, assignees, and dependencies within GitHub repositories.",
  "tools": [
    {
      "name": "list_issues",
      "description": "Lists issues based on various criteria, including issues assigned to the authenticated user across all visible repositories, issues within a specific organization, or issues in a particular repository. Agents can filter issues by state (open, closed, all), labels, assignee, creator, mentioned users, milestone, issue type, or custom issue field values.",
      "parameters": [
        {
          "name": "org",
          "type": "string",
          "required": false,
          "description": "The organization name to list issues from.",
          "enum": null
        },
        {
          "name": "owner",
          "type": "string",
          "required": false,
          "description": "The account owner of the repository. Required when 'repo' is provided.",
          "enum": null
        },
        {
          "name": "repo",
          "type": "string",
          "required": false,
          "description": "The name of the repository. Required when 'owner' is provided.",
          "enum": null
        },
        {
          "name": "filter",
          "type": "string",
          "required": false,
          "description": "Indicates which sorts of issues to return. Can be 'assigned' (issues assigned to you), 'created' (issues created by you), 'mentioned' (issues mentioning you), 'subscribed' (issues you're subscribed to), 'all' (all issues you can see), or 'repos' (all issues in owned/member repositories).",
          "enum": null
        },
        {
          "name": "state",
          "type": "string",
          "required": false,
          "description": "Indicates the state of the issues to return. Can be 'open', 'closed', or 'all'.",
          "enum": null
        },
        {
          "name": "labels",
          "type": "string",
          "required": false,
          "description": "A comma-separated list of label names to filter by. Example: 'bug,ui,@high'.",
          "enum": null
        },
        {
          "name": "sort",
          "type": "string",
          "required": false,
          "description": "What to sort results by. Can be 'created', 'updated', 'comments', or 'due_date'.",
          "enum": null
        },
        {
          "name": "direction",
          "type": "string",
          "required": false,
          "description": "The direction to sort the results by. 'asc' or 'desc'. Ignored without the 'sort' parameter.",
          "enum": null
        },
        {
          "name": "since",
          "type": "string",
          "required": false,
          "description": "Only show results that were last updated after the given time. This is a timestamp in ISO 8601 format: `YYYY-MM-DDTHH:MM:SSZ`.",
          "enum": null
        },
        {
          "name": "milestone",
          "type": "string",
          "required": false,
          "description": "Filter by milestone. Pass an integer for its `number` field, '*' for issues with any milestone, or 'none' for issues without milestones.",
          "enum": null
        },
        {
          "name": "assignee",
          "type": "string",
          "required": false,
          "description": "Filter by assignee. Pass a username, 'none' for issues with no assignee, or '*' for issues assigned to any user.",
          "enum": null
        },
        {
          "name": "creator",
          "type": "string",
          "required": false,
          "description": "Filter by the user that created the issue.",
          "enum": null
        },
        {
          "name": "mentioned",
          "type": "string",
          "required": false,
          "description": "Filter by a user that's mentioned in the issue.",
          "enum": null
        },
        {
          "name": "issue_field_values",
          "type": "string",
          "required": false,
          "description": "A comma-separated list of issue field filters in 'field_slug:value' format. Example: 'priority:Urgent,severity:High'. Requires issue fields to be enabled.",
          "enum": null
        },
        {
          "name": "type",
          "type": "string",
          "required": false,
          "description": "Filter by issue type name, '*' for any type, or 'none' for no type.",
          "enum": null
        }
      ],
