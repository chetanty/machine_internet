# Primary Gemini agent
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Fallback models tried on the SAME API key when the primary model hits its daily quota.
# Each model has an independent quota pool — add any models that still have capacity.
# To list all available model IDs: python -c "import asyncio; from google import genai; ..."
# Confirmed available models (as of 2026-05):
#   gemini-3.1-flash-lite   gemini-2.5-flash-lite   gemini-2.0-flash-lite
#   gemini-3.5-flash        gemini-2.0-flash         gemini-3.1-flash-lite-preview
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite,gemini-2.0-flash-lite

# Additional API keys (separate Google accounts) — tried after all model fallbacks fail.
# GEMINI_MODEL_N defaults to GEMINI_MODEL if blank.
GEMINI_API_KEY_2=
GEMINI_MODEL_2=

GEMINI_API_KEY_3=
GEMINI_MODEL_3=

GEMINI_API_KEY_4=
GEMINI_MODEL_4=

GEMINI_API_KEY_5=
GEMINI_MODEL_5=

# OpenAI fallback — used after all Gemini agents are exhausted
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini   # switch to gpt-4o only if condensation quality on complex APIs is noticeably worse

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uaa
API_PORT=8001
